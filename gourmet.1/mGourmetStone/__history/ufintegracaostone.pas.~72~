       mmlog.Lines.Add(Datetimetostr(now())+' '+'Código da Modalidade do Pedido '+orcssaiorcchave.AsString+' '+dtlrecmdacodigo.asstring);

      if (dtlrecmdacodigo.AsInteger=78) then // online
      begin

        mor.close;
        mor.ParamByName('orcchave').AsString:=orcssaiorcchave.AsString;
        mor.Open;

        if not mor.IsEmpty then
        begin


          mes.Close;
          mes.ParamByName('meschave').AsString:=mor.FieldByName('meschave').AsString;
          mes.FilterSQL:='mes.temcodigo=2';
          mes.Open;

          mmlog.Lines.Add(Datetimetostr(now())+' '+'  Vai emitir NFCe OrcChave: '+orcssaiorcchave.AsString);

          GeraNFCe(orcssaiorcchave.AsString);

          mmlog.Lines.Add(Datetimetostr(now())+' '+'  Emitiu NFCe OrcChave: '+orcssaiorcchave.AsString);

        end;

      end;

      orcssai.Next;
    end;

    orcssai.RecNo:=i;

    orcssai.RecNo:=i;
    orcssai.EnableControls;

  except
  on E: Exception do
    begin
      mmlog.Lines.Add(Datetimetostr(now())+e.ClassName+' '+' linha 2654 '+e.Message);
    end;
  end;


end;

