    while not orcssai.Eof do
    begin
      mostra.Position:= mostra.Position+1;

      mmlog.Lines.Add(Datetimetostr(now())+' '+'Verificando Recebimento de Pedidos');

      dtlrec.Close;
      dtlrec.ParamByName('orcchave').AsInteger:=orcssaiorcchave.AsInteger;
      dtlrec.ParamByName('flacodigo').AsInteger:=1;
      dtlrec.Open;

       mmlog.Lines.Add(Datetimetostr(now())+' '+'Código da Modalidade do Pedido '+orcssaiorcchave.AsString+' '+dtlrecmdacodigo.asstring);

      if (dtlrecmdacodigo.AsInteger=4) or
         (dtlrecmdacodigo.AsInteger=5) or
