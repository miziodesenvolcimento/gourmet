          rpworc.Next;
        end;

      end;

      orcssai.Next;
    end;



    mmlog.Lines.Add(Datetimetostr(now())+' '+'Verificando Online');

    mostra.Max:=orcssai.RecordCount;
    mostra.Position:= 0;


    while not orcssai.Eof do
    begin

      mostra.Position:= mostra.Position+1;

      mmlog.Lines.Add(Datetimetostr(now())+' '+'Verificando Recebimento  online de Pedidos');

      dtlrec.Close;
      dtlrec.ParamByName('orcchave').AsInteger:=orcssaiorcchave.AsInteger;
      dtlrec.ParamByName('flacodigo').AsInteger:=1;
