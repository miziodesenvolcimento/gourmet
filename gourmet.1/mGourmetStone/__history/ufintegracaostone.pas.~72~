      begin


        rpworc.Close;
        rpworc.ParamByName('orcchave').AsInteger:=orcssaiorcchave.AsInteger;
        rpworc.Open;

        while not rpworc.Eof do
        begin

          rpw.close;
          rpw.ParamByName('orcchave').AsString:=orcssaiorcchave.AsString;
          rpw.ParamByName('rpwstatus').AsString:='EM ABERTO';
          rpw.ParamByName('cznchave').AsInteger:=rpworccznchave.AsInteger;
